FROM node:20-slim

WORKDIR /app

# Install only production deps
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev 2>/dev/null || npm install --omit=dev

# Copy the exporter script
COPY baileys_export.mjs ./

# Persistent volumes for auth + output data
VOLUME ["/app/output", "/app/.baileys_auth"]

CMD ["node", "baileys_export.mjs"]
